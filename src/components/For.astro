---
const audiences = [
  { tag: "NDT", label: "Non-destructive testing", note: "Level II/III cert tracking, ISO 9001, project-based." },
  { tag: "CRANE", label: "Crane & rigging", note: "Operator certs, lift plans, load charts, ANSI/ASME." },
  { tag: "INSP", label: "Industrial inspection", note: "API 510/570/653, turnaround work, chain-of-custody." },
  { tag: "OIL", label: "Oilfield & pipeline services", note: "H2S-qualified crews, multi-well dispatch, sign-off." },
  { tag: "WIND", label: "Wind & renewables", note: "GWO-certified techs, tower access, campaign reporting." },
  { tag: "GEN", label: "Power generation services", note: "Outage work, permit-to-work, executive rollups." },
];
---
<section id="for" class="border-b border-hairline bg-ink text-paper">
  <div class="container-wide py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 md:col-span-4">
        <p class="eyebrow text-hairline">§ 03 — Who it's for</p>
      </div>
      <div class="col-span-12 md:col-span-8">
        <h2 class="display text-4xl md:text-6xl">
          Built for teams that<br />
          <span class="text-yellow">live on the road.</span>
        </h2>
      </div>
    </div>
    <div class="rule-thick border-paper" />
    {audiences.map((a) => (
      <div class="grid grid-cols-12 gap-6 py-8 border-b border-steel/40 items-center">
        <div class="col-span-3 md:col-span-2">
          <span class="inline-block border border-yellow text-yellow font-mono text-xs px-2 py-1">
            {a.tag}
          </span>
        </div>
        <div class="col-span-9 md:col-span-6 display text-2xl md:text-3xl">
          {a.label}
        </div>
        <div class="col-span-12 md:col-span-4 text-sm text-hairline">
          {a.note}
        </div>
      </div>
    ))}
  </div>
</section>
