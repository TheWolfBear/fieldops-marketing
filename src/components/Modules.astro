---
const modules = [
  {
    n: "01",
    title: "Dispatch",
    body: "Assign crews to jobs, wells, or turnarounds. Match technicians to certifications required. Push updates to the field in real time.",
    detail: "Calendar · Cert-matched routing · Live status",
  },
  {
    n: "02",
    title: "Timesheets",
    body: "Field crews clock in from the app. Client sign-off captured on-site. Per diem, mileage, and payroll exports every Friday.",
    detail: "Mobile clock-in · Client sign-off · Payroll & per diem",
  },
  {
    n: "03",
    title: "Certifications",
    body: "Every tech, every card, every expiration — tracked. ASNT, GWO, H2S, TWIC, medical, ISO 9001. Alerts before anything lapses. Audit-ready.",
    detail: "ASNT · GWO · H2S · ISO 9001 · Auto alerts",
  },
  {
    n: "04",
    title: "CRM",
    body: "Operator accounts, contacts, RFPs, and pipeline in the same place the work gets done. Won opportunities become active projects automatically.",
    detail: "Pipeline · Accounts · Auto-project creation",
  },
  {
    n: "05",
    title: "Reports",
    body: "Field reports, client deliverables, and executive rollups. Filtered by client, well, or crew. Export chain-of-custody PDFs with your brand.",
    detail: "Field reports · Client PDFs · Executive rollups",
  },
];
---
<section id="platform" class="border-b border-hairline">
  <div class="container-wide py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 md:col-span-4">
        <p class="eyebrow">§ 02 — The platform</p>
      </div>
      <div class="col-span-12 md:col-span-8">
        <h2 class="display text-4xl md:text-6xl">
          Five modules.<br />One database.<br />
          <span class="text-steel">No integrations required.</span>
        </h2>
      </div>
    </div>

    <div class="rule-thick" />

    {modules.map((m, i) => (
      <div class="grid grid-cols-12 gap-6 py-10 border-b border-hairline">
        <div class="col-span-12 md:col-span-2">
          <p class="eyebrow">{m.n}</p>
        </div>
        <div class="col-span-12 md:col-span-4">
          <h3 class="display text-4xl md:text-5xl">{m.title}</h3>
        </div>
        <div class="col-span-12 md:col-span-4 text-base leading-relaxed">
          {m.body}
        </div>
        <div class="col-span-12 md:col-span-2 text-xs font-mono text-steel">
          {m.detail}
        </div>
      </div>
    ))}
  </div>
</section>
