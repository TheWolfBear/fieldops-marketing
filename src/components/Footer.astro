---
const year = new Date().getFullYear();
---
<footer class="bg-ink text-paper">
  <div class="container-wide py-16 grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-4">
      <a href="/" class="display text-3xl leading-none">
        FieldOps<span class="text-yellow">.</span>
      </a>
      <p class="mt-4 text-sm text-hairline max-w-xs">
        The operating system for inspection, service, and trades companies.
      </p>
    </div>
    <div class="col-span-6 md:col-span-2">
      <p class="eyebrow text-hairline mb-4">Platform</p>
      <ul class="space-y-2 text-sm">
        <li><a href="#platform" class="hover:text-yellow">Modules</a></li>
        <li><a href="#for" class="hover:text-yellow">Who it's for</a></li>
        <li><a href="#how" class="hover:text-yellow">How it works</a></li>
      </ul>
    </div>
    <div class="col-span-6 md:col-span-2">
      <p class="eyebrow text-hairline mb-4">Company</p>
      <ul class="space-y-2 text-sm">
        <li><a href="mailto:hello@fieldops.com" class="hover:text-yellow">Contact</a></li>
        <li><a href="https://gir-intranet.lovable.app" target="_blank" rel="noopener" class="hover:text-yellow">Sign in</a></li>
      </ul>
    </div>
    <div class="col-span-12 md:col-span-4 text-xs font-mono text-steel">
      <p>Built by Wolf Bear Agency.</p>
      <p class="mt-1">© {year} FieldOps. All rights reserved.</p>
    </div>
  </div>
</footer>
